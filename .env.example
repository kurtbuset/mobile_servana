# Servana Mobile - Environment Variables Template
# Copy this file to .env and update with your values

# API Configuration
API_URL=http://172.26.240.1:5000
API_TIMEOUT=30000

# Socket Configuration
SOCKET_URL=http://172.26.240.1:5000
SOCKET_RECONNECTION=true

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_LOGGING=true
ENABLE_DEBUG_MENU=true

# App Configuration
APP_NAME=Servana Mobile
APP_VERSION=1.0.0

# Development Settings
DEV_MODE=true
LOG_LEVEL=debug

# Production Settings (uncomment for production)
# API_URL=https://api.servana.com
# SOCKET_URL=https://api.servana.com
# ENABLE_ANALYTICS=true
# ENABLE_LOGGING=false
# DEV_MODE=false
